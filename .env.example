# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Slides API (optional, for Google Slides export)
GOOGLE_SLIDES_CREDENTIALS_PATH=path/to/credentials.json

# Default Provider (openai, anthropic, google, perplexity)
DEFAULT_AI_PROVIDER=anthropic

# Company name override (optional, overrides config.json)
# FORGE_COMPANY=Your Company

